@page
@model CalculadoraHorasUteisModel
@{
    ViewData["Title"] = "Calculadora de Horas Úteis";
}

<div class="main-container workdays-page">
    <div class="page-heading">
        <div>
            <h2>
                <i class="bi bi-calculator"></i>
                Calculadora de Horas Úteis
            </h2>
            <p>Calcula o período de folha de 26 do mês informado até 25 do mês seguinte.</p>
        </div>
        <span class="status-badge status-open">Barueri/SP</span>
    </div>

    <form method="post" class="fixed-control-panel workdays-form">
        <div class="workdays-form-grid">
            <div>
                <label class="form-label" asp-for="Input.MesReferencia">Mês de referência</label>
                <input asp-for="Input.MesReferencia" class="form-control" type="month" required />
                <span asp-validation-for="Input.MesReferencia" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Input.HorasPorDia">Horas por dia</label>
                <input asp-for="Input.HorasPorDia" class="form-control" type="number" min="1" max="24" step="1" required />
                <span asp-validation-for="Input.HorasPorDia" class="text-danger small"></span>
            </div>
            <div class="workdays-actions">
                <button type="submit" class="btn btn-success responsive-button">
                    <i class="bi bi-check2-circle"></i>
                    Calcular
                </button>
            </div>
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>
    </form>

    @if (Model.Resultado is not null)
    {
        <section class="workdays-result-shell">
            @if (!string.IsNullOrWhiteSpace(Model.AvisoFeriados))
            {
                <div class="import-preview mb-3">
                    <strong>Atenção:</strong> @Model.AvisoFeriados
                </div>
            }

            <div class="workdays-period">
                <span class="metric-label">Período calculado</span>
                <strong>@Model.Resultado.Periodo</strong>
            </div>

            <div class="workdays-summary-grid">
                <div class="metric-card metric-good">
                    <small>Dias úteis</small>
                    <strong>@Model.Resultado.DiasUteis</strong>
                    <span>@Model.Resultado.HorasPorDia h por dia</span>
                </div>
                <div class="metric-card">
                    <small>Total de horas</small>
                    <strong>@Model.Resultado.TotalHorasUteis h</strong>
                    <span>Base para conferência mensal</span>
                </div>
                <div class="metric-card">
                    <small>Dias corridos</small>
                    <strong>@Model.Resultado.DiasTotais</strong>
                    <span>@Model.Resultado.DiasNaoUteis dias não úteis</span>
                </div>
                <div class="metric-card metric-warn">
                    <small>Feriados</small>
                    <strong>@Model.Resultado.Feriados.Count</strong>
                    <span>No período considerado</span>
                </div>
            </div>

            <div class="workdays-holidays">
                <div class="fixed-table-header">
                    <div>
                        <h4>
                            <i class="bi bi-calendar-event"></i>
                            Feriados considerados
                        </h4>
                        <p>Nacionais, SP, Barueri e principais feriados móveis.</p>
                    </div>
                </div>

                @if (Model.Resultado.Feriados.Count == 0)
                {
                    <div class="holiday-empty">Nenhum feriado no período.</div>
                }
                else
                {
                    <div class="holiday-list">
                        @foreach (var feriado in Model.Resultado.Feriados)
                        {
                            <div class="holiday-item">
                                <div class="holiday-date">
                                    <strong>@feriado.Data.ToString("dd")</strong>
                                    <span>@feriado.Data.ToString("MMM")</span>
                                </div>
                                <div>
                                    <strong>@feriado.Nome</strong>
                                    <span>@feriado.Data.ToString("dddd, dd/MM/yyyy")</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    }
</div>
