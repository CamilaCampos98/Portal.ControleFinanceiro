@using Microsoft.AspNetCore.Mvc.RazorPages
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - GRANA</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Portal.ControleFinanceiro.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header class="app-header">
        <div class="container-fluid app-header__inner">
            <a class="brand-link" asp-page="/Index" aria-label="Ir para a página inicial">
                <span class="brand-mark"><i class="bi bi-cash-coin"></i></span>
                <span>
                    <span class="brand-name">GRANA</span>
                    <span class="brand-subtitle">Controle financeiro</span>
                </span>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-sm btn-outline-light" asp-page="/Shared/Logout">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Sair</span>
                </a>
            }
        </div>
    </header>

    <nav class="app-nav" aria-label="Navegação principal">
        <div class="container-fluid app-nav__inner">
            <a class="nav-action @(currentPage == "/Controle/RegistrarCompra" ? "active" : "")" asp-page="/Controle/RegistrarCompra">
                <i class="bi bi-cart-plus"></i>
                <span>Compra</span>
            </a>
            <a class="nav-action @(currentPage == "/Controle/RegistrarEntrada" ? "active" : "")" asp-page="/Controle/RegistrarEntrada">
                <i class="bi bi-wallet2"></i>
                <span>Entrada</span>
            </a>
            <a class="nav-action @(currentPage == "/Controle/Resumo" ? "active" : "")" asp-page="/Controle/Resumo">
                <i class="bi bi-bar-chart-line"></i>
                <span>Resumo</span>
            </a>
            <a class="nav-action @(currentPage == "/Controle/Fixos" ? "active" : "")" asp-page="/Controle/Fixos">
                <i class="bi bi-calendar-check"></i>
                <span>Fixos</span>
            </a>
            <a class="nav-action @(currentPage == "/Controle/CalculadoraHorasUteis" ? "active" : "")" asp-page="/Controle/CalculadoraHorasUteis">
                <i class="bi bi-clock-history"></i>
                <span>Horas úteis</span>
            </a>
        </div>
    </nav>

    <div class="container-fluid app-page">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container-fluid">
            GRANA &copy; 2026
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>



    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
